# Scanfor Red — example environment configuration
#
# NOTE: this app does not load .env files itself (no python-dotenv dependency) —
# these are plain OS environment variables. Export them in your shell, put them
# in docker-compose.yml's `environment:` block, or set them in your crontab
# entry. A `.env` file here only has effect if you're using it for Docker
# Compose's own variable substitution (e.g. ${SCANFOR_PROM_SOURCE}), not for
# values the Python app reads directly.

# ─── .prom ingestion ───────────────────────────────────────────────────────────
SCANFOR_PROM_FILE_PATH=/Users/bpb/Documents/Test_Data
SCANFOR_PROM_POLL_SECONDS=60
SCANFOR_ENABLE_PROM_WATCHER=false

# ─── Database ───────────────────────────────────────────────────────────────────
SCANFOR_DB_PATH=backend/database/scanfor_red.db

# ─── Retention / offloading ─────────────────────────────────────────────────────
SCANFOR_RETENTION_DAYS=90
SCANFOR_EXPORT_DIR=backend/database/exports

# ─── Actionable vs. noise classification ────────────────────────────────────────
# Case-insensitive, comma-separated. Blank or invalid falls back to red,yellow.
SCANFOR_ACTIONABLE_COLORS=red,yellow
# Accepts true/1/yes/on (case-insensitive) as true.
SCANFOR_SUPPRESS_KNOWN_ERRORS=true
